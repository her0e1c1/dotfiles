{
  "name": "playwright-dev",
  "dockerComposeFile": "compose.yaml",
  "service": "dev",
  "workspaceFolder": "/workspace",
  "features": {
    // Required to access a lightweight desktop session inside the dev container.
    "ghcr.io/devcontainers/features/desktop-lite:1": {
      "webPort": "6080"
    },
    "ghcr.io/devcontainers/features/common-utils:2": {},
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers/features/copilot-cli:1": {}
  },
  "postCreateCommand": "npm ci",
  "mounts": [
    // Required so Copilot CLI auth and config survive devcontainer rebuilds.
    "type=volume,source=playwright_copilot_home,target=/root/.copilot"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-playwright.playwright",
        "github.copilot",
        "github.copilot-chat"
      ]
    }
  },
  "forwardPorts": [
    9323,
    6080
  ],
  "remoteUser": "root"
}
