COMPOSE_PROJECT_NAME=dev-gcp

# DEFAULT
DEFAULT_LOCATION=asia-northeast1
DEFAULT_ZONE=asia-northeast1-a

# GCP PROJECT
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
CLOUDSDK_CORE_PROJECT=your-gcp-project-id
TF_VAR_project_id=your-gcp-project-id

# GKE
CLUSTER_NAME=your-gke-cluster-name

# MYSQL
CLOUDSQL_CONNECTION_NAME=your-gcp-project-id:asia-northeast1:your-mysql-instance
MYSQL_HOST=proxy
MYSQL_PORT=3306
MYSQL_USER=your-mysql-user
MYSQL_PWD=your-mysql-password
MYSQL_DATABASE=your-database-name
