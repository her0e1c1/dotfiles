# Required so gcloud, kubectl, and Terraform operate against the same GCP project by default.
CLOUDSDK_CORE_PROJECT=your-gcp-project-id

# Required so gcloud always uses the shared config directory mounted into every service.
CLOUDSDK_CONFIG=/root/.config/gcloud

# Required so gcloud compute and GKE commands have a default region.
CLOUDSDK_COMPUTE_REGION=asia-northeast1

# Required so zonal GKE and compute commands have a default zone.
CLOUDSDK_COMPUTE_ZONE=asia-northeast1-a

# Required so ADC-aware tools use the credential file created by `make auth`.
GOOGLE_APPLICATION_CREDENTIALS=/root/.config/gcloud/application_default_credentials.json

# Required because some tools and Terraform modules read the project id from this generic variable.
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Required so kubectl reads and writes cluster contexts in the shared kube volume.
KUBECONFIG=/root/.kube/config

# Required because many Terraform configurations read the target project from TF_VAR_project_id.
TF_VAR_project_id=your-gcp-project-id
